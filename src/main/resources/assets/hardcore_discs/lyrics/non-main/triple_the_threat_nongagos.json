    [
      {"text": "HEH, I'M THAT'S WHAT YOU WERE EXPECTING US ", "font": "hardcore_discs:papyrus_ut"}
    ],
    [
      {"text": "TO SAY, ISN'T THAT RIGHT HUMAN?", "font": "hardcore_discs:papyrus_ut"}
    ],
    {"setFont": "hardcore_discs:dtm_sans"},
    "Burn. In. Hell.",
    "",
    "<insert sans flashbacks>",
